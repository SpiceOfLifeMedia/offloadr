# =============================================================================
# Offloadr — Environment Variables (EXAMPLE)
# =============================================================================
# Copy this file to `.env` and fill in real values, OR add these as secrets in
# your host (Replit Secrets / your platform's env settings).
#
# NEVER commit a real `.env` file. Values below are FAKE placeholders only.
# Lines marked [SECRET] are sensitive — treat them like passwords.
# =============================================================================

# --- Core (required) --------------------------------------------------------

# [SECRET] Postgres connection string used by the API server and Drizzle.
DATABASE_URL=postgres://user:password@host:5432/offloadr

# [SECRET] Secret used to sign session cookies. Use a long random string (>=32 chars).
SESSION_SECRET=replace_with_a_long_random_string_at_least_32_chars

# [REQUIRED] Port the API server listens on. The server AND the web build fail
# to start if this is unset (the host usually injects it).
PORT=8080

# Application stage: production | pilot | dev
OFFLOADR_ENV=pilot

# Node environment: development | production
NODE_ENV=production

# --- Routing / static serving (optional) ------------------------------------

# URL prefix the API is mounted under (default: /api).
API_MOUNT_PATH=/api

# Base path the built web bundle is served from (default: /).
WEB_BASE_PATH=/

# [REQUIRED] Build-time base path for the Vite web app. The web build fails if
# this is unset. Use "/" for a root deployment.
BASE_PATH=/

# Absolute path to the built web app output. When set, the API serves the SPA.
# NOTE: the Vite build outputs to dist/public, so this MUST end in /dist/public.
STATIC_WEB_DIR=/app/artifacts/offloadr-app/dist/public

# Public URL of the deployed app (used in emails/links).
APP_BASE_URL=https://your-app.example.com

# --- Storage ----------------------------------------------------------------

# Storage backend: fs (local disk, default) | s3 (S3 / Cloudflare R2 compatible)
STORAGE_DRIVER=fs

# Local directory for the `fs` driver.
STORAGE_FS_ROOT=/app/storage

# Temp directory for incoming uploads (multer).
UPLOADS_DIR=/tmp/uploads

# --- S3 / R2 (required only when STORAGE_DRIVER=s3) --------------------------

STORAGE_S3_REGION=auto
STORAGE_S3_BUCKET=offloadr-uploads
STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Use path-style addressing (true) for S3-compatible stores like MinIO.
STORAGE_S3_FORCE_PATH_STYLE=false
# [SECRET]
STORAGE_S3_ACCESS_KEY_ID=your_access_key_id
# [SECRET]
STORAGE_S3_SECRET_ACCESS_KEY=your_secret_access_key

# --- Google Drive transfers via rclone (optional) ---------------------------
# Actual rclone credentials live in rclone's own config (~/.config/rclone/rclone.conf),
# NOT in these variables. These only point at the configured remote.

RCLONE_REMOTE_NAME=gdrive
RCLONE_REMOTE_PATH=Offloadr/Uploads
# Path to an rclone config file (alternative to inline service-account creds).
RCLONE_CONFIG=/home/youruser/.config/rclone/rclone.conf
GDRIVE_UPLOAD_ROOT=Offloadr/Uploads
GDRIVE_SHARED_DRIVE_ID=
# [SECRET] JSON service-account key (single-line JSON) if using the Google Drive API directly.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}

# Max concurrent rclone transfers.
TRANSFER_CONCURRENCY=2

# --- Email (optional) -------------------------------------------------------

# [SECRET] Resend API key for transactional email.
RESEND_API_KEY=re_your_resend_api_key

# Upload notification recipient / sender (code falls back to built-in defaults).
UPLOAD_NOTIFICATION_EMAIL=info@example.com
UPLOAD_NOTIFICATION_FROM=notifications@example.com

# Render-complete notification recipient / sender (code falls back to defaults).
RENDER_NOTIFICATION_EMAIL=info@example.com
RENDER_NOTIFICATION_FROM=notifications@example.com

# --- Misc (optional) --------------------------------------------------------

# [SECRET] Salt used to hash client IP addresses.
IP_HASH_SALT=replace_with_a_random_salt

# Toggle the student accounts portal: true | false
STUDENT_ACCOUNTS_ENABLED=false

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Set to 1 to disable API rate limiting (dev only).
DISABLE_RATE_LIMIT=0
