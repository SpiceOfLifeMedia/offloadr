{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/offloadr-app run build",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://workspaceoffloadr-api-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!assets/|images/|videos/|favicon|apple-touch-icon|opengraph).*)",
      "destination": "/index.html"
    }
  ]
}
