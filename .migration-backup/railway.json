{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/offloadr-api run build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/offloadr-api run start",
    "healthcheckPath": "/api/live",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
