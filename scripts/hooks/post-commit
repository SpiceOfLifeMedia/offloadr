#!/usr/bin/env bash
set -euo pipefail

if [ -z "${GITHUB_TOKEN:-}" ]; then
  echo "post-commit: GITHUB_TOKEN not set, skipping GitHub push." >&2
  exit 0
fi

REMOTE_URL="https://${GITHUB_TOKEN}@github.com/SpiceOfLifeMedia/offloadr.git"

echo "post-commit: pushing to GitHub..."
git push "$REMOTE_URL" main:main 2>&1 || echo "post-commit: GitHub push failed (non-fatal)." >&2
